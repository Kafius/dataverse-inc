<!-- IMPACT NUMBERS -->
  <section class="bg-brand py-12 px-[5%]">
    <div class="max-w-300 mx-auto grid grid-cols-2 gap-8 text-center lg:grid-cols-4">
      {[
        { num: '3', label: 'Years of Celebrations' },
        { num: '10+', label: 'Annual Company Events' },
        { num: '3×', label: 'Ati-Atihan Participations' },
        { num: '1', label: 'Charity Outreach' },
      ].map(i => (
        <div>
          <span class="font-serif text-[2.5rem] text-navy block leading-[1.1]">{i.num}</span>
          <span class="text-[0.82rem] text-navy/70 font-semibold tracking-[0.04em]">{i.label}</span>
        </div>
      ))}
    </div>
  </section>
