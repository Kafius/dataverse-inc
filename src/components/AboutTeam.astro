---
const team = [
  { name: 'Robin De Leon', role: 'Chief Information Officer', bio: '15 years in BPO leadership, Alexandra founded Dataverse with a vision of precision-first outsourcing.' },
  { name: 'Caroline De Leon', role: 'Chief Executive Officer', bio: 'Oversees day-to-day operations and ensures every client engagement exceeds expectations.' },
  { name: 'Dennis Alfred De Leon', role: 'Director of Sales, Marketing & Business Development', bio: 'A certified medical billing specialist with a decade of coding and compliance expertise.' },
  { name: 'Crystal Mae Tacadena', role: 'Team Lead', bio: 'Dedicated to building lasting relationships and ensuring seamless onboarding for every client.' },
  { name: 'Kharen Abayon', role: 'Team Lead', bio: 'Leads our data entry and back-office teams with a relentless focus on quality and throughput.' },
  { name: 'Luis Morales', role: 'Director, Call Center Ops', bio: 'Manages our call center division, delivering outstanding support experiences at scale.' },
  { name: 'Samantha Wells', role: 'Entertainment Services Lead', bio: 'Specializes in cue sheet processing and music rights documentation for the entertainment industry.' },
  { name: 'Kevin Park', role: 'Head of Technology', bio: 'Drives the tools, systems, and infrastructure that keep Dataverse efficient and secure.' },
  { name: 'Rachel Torres', role: 'HR & Talent Manager', bio: 'Builds the Dataverse culture by recruiting exceptional people and developing their careers.' },
  { name: 'Andre Williams', role: 'Quality Assurance Lead', bio: 'Champions our multi-layer QA process, ensuring every deliverable meets the highest standards.' },
  { name: 'Sofia Nguyen', role: 'Senior Transcription Specialist', bio: 'Leads our transcription team with expertise in medical, legal, and media content.' },
  { name: 'David Kim', role: 'Client Relations Manager', bio: 'Serves as the day-to-day point of contact for our key accounts, ensuring seamless communication.' },
];
---

<!-- TEAM -->
<section class="section bg-cream pt-0" id="team">
  <div class="section-inner">
    <div class="text-center mb-15">
      <span class="section-eyebrow">Our People</span>
      <h2 class="section-h2">Meet the Dataverse team</h2>
      <div class="divider center"></div>
      <p class="section-lead mx-auto mt-4">Our strength is our people. Every member of the Dataverse team brings specialized expertise, a collaborative spirit, and a shared commitment to excellence.</p>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {team.map(member => (
        <div class="bg-white rounded-2xl overflow-hidden border border-black/7 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_20px_50px_rgba(26,13,46,0.1)]">
          <div class="w-full aspect-square bg-gradient-to-br from-[#dce4ef] to-[#c5d2e4] flex items-center justify-center text-5xl relative after:content-['Photo_Placeholder'] after:absolute after:bottom-2.5 after:text-[0.65rem] after:tracking-[0.08em] after:uppercase after:text-navy/30">
            👤
          </div>
          <div class="px-5 py-4.5">
            <div class="font-bold text-[0.95rem] text-navy mb-0.5">{member.name}</div>
            <div class="text-[0.8rem] text-brand font-semibold mb-2">{member.role}</div>
            <div class="text-[0.8rem] text-muted leading-[1.55]">{member.bio}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
