---
const values = [
  { icon: '🎯', title: 'Precision', body: 'Multi-layer QA ensures accuracy on every project, every time.' },
  { icon: '🤝', title: 'Partnership', body: 'We invest in your success as if it were our own.' },
  { icon: '🔒', title: 'Security', body: 'Your data is handled with the highest standards of confidentiality.' },
  { icon: '⚡', title: 'Agility', body: 'Scalable capacity to meet your needs as they evolve.' },
];

const milestones = [
  { year: '2021', title: 'Dataverse Founded', body: 'Launched as a boutique data entry and document processing firm serving local businesses.' },
  { year: '2022', title: 'Entertainment & Music Sector', body: 'Established specialized cue sheet processing services for the entertainment industry.' },
  { year: 'Today', title: 'Growing Stronger', body: 'A 100+ person team serving hundreds of clients across multiple industries with precision and pride.' },
];
---

<!-- STORY -->
<section class="section">
  <div class="section-inner grid grid-cols-1 gap-12 items-start lg:grid-cols-2 lg:gap-20">
    <div>
      <span class="section-eyebrow">Our Story</span>
      <h2 class="section-h2">From humble beginnings<br>to industry leaders</h2>
      <div class="divider"></div>
      <p class="section-lead">Over the years, we've grown from a small data processing team into a full-service outsourcing company serving clients across healthcare, entertainment, finance, and beyond.</p>
      <p class="section-lead mt-4">Our team of dedicated specialists brings deep domain knowledge, rigorous quality controls, and a genuine commitment to your success. We don't just process your work — we become an extension of your team.</p>

      <div class="mt-10">
        {milestones.map(m => (
          <div class="flex gap-5 py-5.5 border-b border-black/7 last:border-b-0">
            <div class="font-serif text-2xl text-brand min-w-16 pt-0.5">{m.year}</div>
            <div>
              <h4 class="text-[0.95rem] font-bold text-navy mb-1">{m.title}</h4>
              <p class="text-[0.875rem] text-muted leading-[1.6]">{m.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="sticky top-22">
      <div class="img-placeholder w-full aspect-4/3 mb-5">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
        <span>Company Photo Placeholder</span>
      </div>

      <div class="grid grid-cols-2 gap-3">
        {values.map(v => (
          <div class="bg-cream rounded-xl px-5 py-4.5 border border-black/6">
            <span class="text-2xl block mb-2">{v.icon}</span>
            <h4 class="text-[0.88rem] font-bold text-navy mb-1">{v.title}</h4>
            <p class="text-[0.8rem] text-muted leading-normal">{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
