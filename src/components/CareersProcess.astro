---
const steps = [
  { num: '1', title: 'Apply Online', body: 'Submit your resume and a brief cover letter through our careers portal or email it directly to careers@dataverseinc.com.' },
  { num: '2', title: 'Initial Screening', body: 'A brief phone or video call with our HR team to learn about your background and answer any questions about the role.' },
  { num: '3', title: 'Skills Assessment', body: 'A short practical assessment relevant to the position — a chance to show us what you can do, nothing intimidating.' },
  { num: '4', title: 'Interview', body: 'Meet your potential team and manager. We keep it conversational — we want to get to know you as a person, not just a resume.' },
  { num: '5', title: 'Offer & Onboarding', body: "If it's a great fit, we'll extend an offer and set you up for success with our structured onboarding program." },
];
---
<!-- PROCESS -->
  <section class="section bg-cream">
    <div class="section-inner grid grid-cols-1 gap-12 items-start lg:grid-cols-[1fr_1.5fr] lg:gap-20">
      <div class="lg:sticky lg:top-22">
        <span class="section-eyebrow">How We Hire</span>
        <h2 class="section-h2">A straightforward<br>process.</h2>
        <div class="divider"></div>
        <p class="section-lead">We aim to make applying simple and transparent. Here's what to expect from the moment you apply to the day you join the team.</p>
      </div>
      <div class="flex flex-col">
        {steps.map(s => (
          <div class="flex gap-5 items-start py-6 border-b border-black/8 last:border-b-0">
            <div class="w-10 h-10 shrink-0 bg-brand rounded-full flex items-center justify-center text-[0.9rem] font-extrabold text-navy">{s.num}</div>
            <div>
              <h4 class="text-[0.95rem] font-bold text-navy mb-1.5">{s.title}</h4>
              <p class="text-[0.875rem] text-muted leading-[1.6]">{s.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>