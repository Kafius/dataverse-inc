---
const offices = [
  {
    name: 'Headquarters',
    address: '123 Business Plaza, Suite 400',
    city: 'Your City, State 00000',
    phone: '(000) 000-0000',
  }
];

const socials = [
  { label: 'Instagram', href: '#', icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>` },
  { label: 'X', href: '#', icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>` },
  { label: 'Facebook', href: '#', icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>` },
  { label: 'LinkedIn', href: '#', icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>` },
];
---
<!-- CONTACT BODY -->
  <section class="section">
    <div class="section-inner grid grid-cols-1 gap-12 lg:grid-cols-[1fr_1.2fr] lg:gap-20">

      <!-- LEFT: Info -->
      <div class="pt-2">

        <div class="mb-9">
          <div class="text-[0.72rem] tracking-[0.12em] uppercase text-brand font-bold mb-2.5">Email</div>
          <p class="text-muted text-[0.9rem] leading-[1.8]">
            <a href="mailto:info@dataverseinc.com" class="text-charcoal no-underline transition-colors hover:text-brand">info@dataverseinc.com</a><br>
            <a href="mailto:careers@dataverseinc.com" class="text-charcoal no-underline transition-colors hover:text-brand">careers@dataverseinc.com</a>
          </p>
        </div>

        <div class="mb-9">
          <div class="text-[0.72rem] tracking-[0.12em] uppercase text-brand font-bold mb-2.5">Our Offices</div>
          {offices.map(o => (
            <div class="bg-cream border border-black/7 rounded-xl px-5 py-4.5 mb-2.5">
              <h4 class="text-[0.88rem] font-bold text-navy mb-1.5">{o.name}</h4>
              <p class="text-[0.82rem] text-muted leading-[1.7]">{o.address}<br>{o.city}<br>📞 {o.phone}</p>
            </div>
          ))}
        </div>

        <div class="mb-9">
          <div class="text-[0.72rem] tracking-[0.12em] uppercase text-brand font-bold mb-2.5">Business Hours</div>
          <p class="text-muted text-[0.9rem] leading-[1.8]">
            Monday – Friday: 8:00 AM – 6:00 PM<br>
            Saturday: 9:00 AM – 2:00 PM<br>
            Sunday: Closed
          </p>
        </div>

        <div class="mb-9">
          <div class="text-[0.72rem] tracking-[0.12em] uppercase text-brand font-bold mb-2.5">Follow Us</div>
          <div class="flex gap-2.5">
            {socials.map(s => (
              <a href={s.href} title={s.label} set:html={s.icon}
                 class="w-10.5 h-10.5 bg-cream border border-black/9 rounded-xl flex items-center justify-center text-muted no-underline transition-all hover:bg-brand hover:border-brand hover:text-navy hover:-translate-y-0.5" />
            ))}
          </div>
        </div>

      </div>

      <!-- RIGHT: Form -->
      <div class="bg-navy border border-brand/15 rounded-2xl px-10 py-11 max-sm:px-6 max-sm:py-7">
        <h2 class="font-serif text-2xl text-white mb-1.5">Send us a message</h2>
        <p class="text-[0.875rem] text-white/50 mb-8">Fill out the form below and our team will get back to you within one business day.</p>

        <form id="contactForm">
          <div class="grid grid-cols-2 gap-4 max-sm:grid-cols-1">
            <div class="flex flex-col gap-1.5 mt-4">
              <label for="firstName" class="text-[0.78rem] font-semibold tracking-[0.06em] uppercase text-white/55">First Name</label>
              <input type="text" id="firstName" name="firstName" placeholder="Jane" required
                     class="bg-white/6 border border-white/12 rounded-lg px-4 py-3 text-white text-[0.9rem] outline-none w-full transition-all placeholder:text-white/25 focus:border-brand focus:bg-brand/6" />
            </div>
            <div class="flex flex-col gap-1.5 mt-4">
              <label for="lastName" class="text-[0.78rem] font-semibold tracking-[0.06em] uppercase text-white/55">Last Name</label>
              <input type="text" id="lastName" name="lastName" placeholder="Smith" required
                     class="bg-white/6 border border-white/12 rounded-lg px-4 py-3 text-white text-[0.9rem] outline-none w-full transition-all placeholder:text-white/25 focus:border-brand focus:bg-brand/6" />
            </div>
          </div>

          <div class="flex flex-col gap-1.5 mt-4">
            <label for="email" class="text-[0.78rem] font-semibold tracking-[0.06em] uppercase text-white/55">Email Address</label>
            <input type="email" id="email" name="email" placeholder="jane@company.com" required
                   class="bg-white/6 border border-white/12 rounded-lg px-4 py-3 text-white text-[0.9rem] outline-none w-full transition-all placeholder:text-white/25 focus:border-brand focus:bg-brand/6" />
          </div>

          <div class="flex flex-col gap-1.5 mt-4">
            <label for="phone" class="text-[0.78rem] font-semibold tracking-[0.06em] uppercase text-white/55">Phone Number</label>
            <input type="tel" id="phone" name="phone" placeholder="(000) 000-0000"
                   class="bg-white/6 border border-white/12 rounded-lg px-4 py-3 text-white text-[0.9rem] outline-none w-full transition-all placeholder:text-white/25 focus:border-brand focus:bg-brand/6" />
          </div>

          <div class="flex flex-col gap-1.5 mt-4">
            <label for="inquiry" class="text-[0.78rem] font-semibold tracking-[0.06em] uppercase text-white/55">Inquiry Type</label>
            <select id="inquiry" name="inquiry"
                    class="bg-white/6 border border-white/12 rounded-lg px-4 py-3 text-white text-[0.9rem] outline-none w-full transition-all focus:border-brand focus:bg-brand/6 [&>option]:bg-navy">
              <option value="" disabled selected>Select a topic…</option>
              <option>General Inquiry</option>
              <option>Services & Pricing</option>
              <option>Career Opportunities</option>
              <option>Partnership</option>
              <option>Other</option>
            </select>
          </div>

          <div class="flex flex-col gap-1.5 mt-4">
            <label for="message" class="text-[0.78rem] font-semibold tracking-[0.06em] uppercase text-white/55">Message</label>
            <textarea id="message" name="message" placeholder="Tell us about your needs or questions…" rows="5"
                      class="bg-white/6 border border-white/12 rounded-lg px-4 py-3 text-white text-[0.9rem] outline-none w-full transition-all placeholder:text-white/25 focus:border-brand focus:bg-brand/6 resize-y"></textarea>
          </div>

          <button type="submit" id="submitBtn"
                  class="w-full bg-brand text-navy border-none py-3.5 rounded-lg text-[0.95rem] font-bold cursor-pointer transition-all tracking-[0.04em] mt-6 hover:bg-brand-light hover:-translate-y-px hover:shadow-[0_8px_24px_rgba(139,92,246,0.3)] disabled:opacity-60 disabled:cursor-not-allowed disabled:translate-y-0">
            Send Message
          </button>
        </form>

      </div>
    </div>
  </section>

  <script>
  const form = document.getElementById('contactForm') as HTMLFormElement;
  const btn = document.getElementById('submitBtn') as HTMLButtonElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    btn.textContent = 'Message Sent ✓';
    btn.style.background = '#22c55e';
    btn.style.color = '#fff';
    btn.disabled = true;
    setTimeout(() => {
      btn.textContent = 'Send Message';
      btn.style.background = '';
      btn.style.color = '';
      btn.disabled = false;
      form.reset();
    }, 3000);
  });
</script>